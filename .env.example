# === Server ===
# Port the Express server listens on. Vite proxies /api to this port in dev.
PORT=3001
# 'development' or 'production'. Affects cookie Secure flag, CSP, log level.
NODE_ENV=development

# === Database ===
# Neon connection string. Use the pooled connection URL in production.
# Format: postgres://user:pass@host/db?sslmode=require
DATABASE_URL=

# === Google OAuth ===
# From Google Cloud Console > Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Dev: http://localhost:3001/api/auth/google/callback
# Prod: https://<your-domain>/api/auth/google/callback
GOOGLE_CALLBACK_URL=

# === Session ===
# Random string used to sign session cookies. Min 32 chars in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# === Cloudflare R2 (not used until Phase 7, but required by env validator) ===
R2_PUBLIC_BASE_URL=

# === Client ===
# URL the browser uses to access the frontend. CORS allows only this origin.
# Dev: http://localhost:5173 (Vite default)
# Prod: https://<your-vercel-domain>
CLIENT_URL=http://localhost:5173
